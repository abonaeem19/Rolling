# ==========================================
# Rolling Draw - Environment Configuration
# ==========================================

# Server
PORT=3000
NODE_ENV=production

# Public URL of this app (used for QR Code generation)
# Change this to your actual domain in production
PUBLIC_URL=http://localhost:3000

# Admin Credentials
# Default: admin / admin123 (CHANGE IN PRODUCTION!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Session Secret (CHANGE TO A LONG RANDOM STRING IN PRODUCTION!)
SESSION_SECRET=change-this-to-a-very-long-random-string-please

# Rate Limit on /register (requests per IP per minute)
REGISTER_RATE_LIMIT=10

# Database file path (optional)
# - Local default:  data/rolling.db
# - Railway/Fly:    set to /app/data/rolling.db (matches Volume mount path)
# DB_PATH=/app/data/rolling.db
